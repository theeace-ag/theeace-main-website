{
  "outputDirectory": "theeace-ag.framer.website",
  "trailingSlash": true,
  "cleanUrls": true,
  "routes": [
    {
      "src": "/configurator",
      "dest": "/index.html"
    },
    {
      "src": "/payment",
      "dest": "/index.html"
    },
    {
      "src": "/payments",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "github": {
    "enabled": true,
    "silent": false,
    "autoJobCancelation": true
  }
}