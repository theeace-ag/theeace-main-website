{
  "outputDirectory": "theeace-ag.framer.website",
  "trailingSlash": true,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/configurator",
      "destination": "/index.html"
    },
    {
      "source": "/payment",
      "destination": "/index.html"
    },
    {
      "source": "/payments",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "github": {
    "enabled": true,
    "silent": false,
    "autoJobCancelation": true
  }
}